        {
          "name": "Register Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (error) { console.log(error); }",
                  "const teacher = json?.data?.teacher ?? null;",
                  "if (teacher?.id) { pm.collectionVariables.set('teacherId', String(teacher.id)); pm.environment.set('teacherId', String(teacher.id)); }",
                  "if (teacher?.email) { pm.collectionVariables.set('teacherEmail', teacher.email); pm.environment.set('teacherEmail', teacher.email); }",
                  "if (teacher?.username) { pm.collectionVariables.set('teacherUsername', teacher.username); pm.environment.set('teacherUsername', teacher.username); }",
                  "if (teacher?.major?.id) { pm.collectionVariables.set('teacherMajorId', String(teacher.major.id)); pm.environment.set('teacherMajorId', String(teacher.major.id)); }",
                  "if (teacher?.subject?.id) { pm.collectionVariables.set('teacherSubjectId', String(teacher.subject.id)); pm.environment.set('teacherSubjectId', String(teacher.subject.id)); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
