                { "key": "gender", "value": "{{teacherGender}}", "type": "text" },
                { "key": "major_id", "value": "{{teacherMajorId}}", "type": "text" },
                { "key": "subject_id", "value": "{{teacherSubjectId}}", "type": "text" },
