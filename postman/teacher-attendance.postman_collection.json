    {
      "name": "Teacher Attendance",
      "item": [
        {
          "name": "Attendance Options",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (error) { console.log(error); }",
                  "const data = json?.data ?? {};",
                  "const firstClass = data?.classes?.[0] ?? null;",
                  "if (data?.major?.id) { pm.collectionVariables.set('teacherMajorId', String(data.major.id)); pm.environment.set('teacherMajorId', String(data.major.id)); }",
                  "if (data?.subject?.id) { pm.collectionVariables.set('teacherSubjectId', String(data.subject.id)); pm.environment.set('teacherSubjectId', String(data.subject.id)); }",
                  "if (firstClass?.id) { pm.collectionVariables.set('teacherClassId', String(firstClass.id)); pm.environment.set('teacherClassId', String(firstClass.id)); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{teacherAccessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/teacher/attendance/options",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "teacher", "attendance", "options"]
            },
            "description": "Returns the teacher major, subject, and only the classes valid for attendance based on major_subjects mappings."
          },
          "response": []
        },
